{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting": "Information",
      "Microsoft.AspNetCore.Routing": "Warning",
      "BankingApi.Simulation": "Information",
      "BankingApi.Services": "Information",
      "BankingApi.Consumers": "Information",
      "BankingApi.Controllers": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": false,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss "
      }
    }
  },
  "AllowedHosts": "*",
  "Simulation": {
    "AutoRun": false,
    "IntervalMinutes": 30,
    "DefaultPessoas": 20,
    "DefaultEmpresas": 10,
    "DefaultTransacoes": 100,
    "SaveToMinIO": true
  },
  "Kafka": {
    "BootstrapServers": "kafka:29092",
    "GroupId": "banking-api-prod",
    "AutoOffsetReset": "Earliest",
    "EnableAutoCommit": true,
    "StatisticsIntervalMs": 10000,
    "SessionTimeoutMs": 30000,
    "MaxPollIntervalMs": 300000,
    "Topics": {
      "TransacaoSolicitada": "banking-transacao-solicitada",
      "TransacaoProcessada": "banking-transacao-processada",
      "SaldoAtualizado": "banking-saldo-atualizado",
      "ContaCriada": "banking-conta-criada",
      "PessoaCriada": "banking-pessoa-criada",
      "EmpresaCriada": "banking-empresa-criada"
    }
  },
  "MinIO": {
    "Endpoint": "minio:9000",
    "AccessKey": "admin",
    "SecretKey": "admin123456",
    "UseSSL": false,
    "Region": "us-east-1",
    "BucketReports": "simulation-reports",
    "BucketLogs": "banking-logs",
    "BucketBackups": "banking-backups",
    "BucketExports": "banking-exports"
  },
  "HealthChecks": {
    "Enabled": true,
    "TimeoutSeconds": 30
  }
}